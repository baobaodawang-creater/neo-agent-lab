{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "替换为你的gateway_token"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "custom-api-deepseek-com/deepseek-chat"
        ]
      },
      "models": {
        "anthropic/claude-sonnet-4-6": {},
        "custom-api-deepseek-com/deepseek-chat": {},
        "lmstudio/huihui-qwen3-coder-30b-a3b-instruct-abliterated": {},
        "google/gemini-3.1-pro-preview": {}
      },
      "timeoutSeconds": 600,
      "workspace": "/home/node/.openclaw/workspace"
    },
    "list": [
      {
        "id": "main",
        "model": {
          "primary": "anthropic/claude-sonnet-4-6"
        }
      },
      {
        "id": "pm",
        "model": {
          "primary": "anthropic/claude-sonnet-4-6"
        }
      },
      {
        "id": "analyst",
        "model": {
          "primary": "google/gemini-3.1-pro-preview"
        }
      },
      {
        "id": "search",
        "model": {
          "primary": "custom-api-deepseek-com/deepseek-chat"
        }
      },
      {
        "id": "secretary",
        "model": {
          "primary": "custom-api-deepseek-com/deepseek-chat"
        }
      },
      {
        "id": "ainews",
        "model": {
          "primary": "custom-api-deepseek-com/deepseek-chat"
        }
      },
      {
        "id": "monitor",
        "model": {
          "primary": "custom-api-deepseek-com/deepseek-chat"
        }
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "apiKey": "替换为你的Anthropic_API_Key",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "custom-api-deepseek-com": {
        "baseUrl": "https://api.deepseek.com",
        "apiKey": "替换为你的DeepSeek_API_Key",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "deepseek-chat",
            "contextWindow": 65536,
            "maxTokens": 8192
          }
        ]
      },
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com",
        "apiKey": "替换为你的Google_API_Key",
        "api": "google-generative-ai",
        "models": [
          {
            "id": "gemini-3.1-pro-preview",
            "name": "Gemini 3.1 Pro",
            "contextWindow": 1000000,
            "maxTokens": 8192
          }
        ]
      },
      "lmstudio": {
        "baseUrl": "http://host.docker.internal:1234/v1",
        "apiKey": "lmstudio",
        "api": "openai-completions",
        "models": [
          {
            "id": "huihui-qwen3-coder-30b-a3b-instruct-abliterated",
            "name": "Qwen3-Coder 30B abliterated",
            "contextWindow": 65536,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "accounts": {
        "default": {
          "botToken": "替换为主控bot_token"
        },
        "pm": {
          "botToken": "替换为pm_bot_token"
        },
        "secretary": {
          "botToken": "替换为secretary_bot_token"
        },
        "ainews": {
          "botToken": "替换为ainews_bot_token"
        },
        "monitor": {
          "botToken": "替换为monitor_bot_token"
        }
      }
    }
  },
  "bindings": [
    {
      "agentId": "main",
      "match": {
        "channel": "telegram",
        "accountId": "default"
      }
    },
    {
      "agentId": "pm",
      "match": {
        "channel": "telegram",
        "accountId": "pm"
      }
    },
    {
      "agentId": "secretary",
      "match": {
        "channel": "telegram",
        "accountId": "secretary"
      }
    },
    {
      "agentId": "ainews",
      "match": {
        "channel": "telegram",
        "accountId": "ainews"
      }
    },
    {
      "agentId": "monitor",
      "match": {
        "channel": "telegram",
        "accountId": "monitor"
      }
    }
  ],
  "tools": {
    "web": {
      "search": {
        "apiKey": "替换为你的Brave_Search_API_Key",
        "maxResults": 5,
        "timeoutSeconds": 30
      }
    }
  },
  "plugins": {
    "slots": {
      "memory": "memory-lancedb"
    },
    "entries": {
      "memory-lancedb": {
        "enabled": true,
        "config": {
          "autoCapture": true,
          "autoRecall": true,
          "embedding": {
            "apiKey": "替换为你的Google_API_Key",
            "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai/",
            "model": "gemini-embedding-001",
            "dimensions": 768
          }
        }
      }
    }
  }
}
